{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "node10",
    "ignoreDeprecations": "6.0",
    "target": "ES2020",
    "lib": ["ES2020"],
    "strict": false,
    "noImplicitAny": true,
    "strictNullChecks": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "typeRoots": ["./node_modules/@types", "./types"],
    "types": ["node"]
  },
  "include": ["src/**/*.js", "app.js", "bin/**/*.js"],
  "exclude": ["node_modules", "public/vendor/**/*.js", "**/*.test.js"]
}
