{
  "name": "@mikaello/avrodoc-plus",
  "description": "Documentation tool for Avro schemas. Forked from https://github.com/leosilvadev/avrodoc-plus.",
  "version": "2.0.0",
  "author": "mikaello https://github.com/mikaello",
  "type": "module",
  "bin": "./bin/avrodoc-plus.js",
  "scripts": {
    "start": "node src/cli.js",
    "server": "node app.js",
    "test": "node --test src/avrodoc.test.js",
    "lint": "eslint --ext js,ts,tsx src public/js app.js",
    "typecheck": "tsc --noEmit",
    "test:ci": "npm run check-format && npm run lint && npm run typecheck && npm run test",
    "check-format": "prettier --check \"**/!(vendor|stylesheets|bootstrap)/(*.ts?(x)|*.js?(x)|*.json|*.css|*.html|*.md)\"",
    "format": "prettier --write \"**/!(vendor|stylesheets|bootstrap)/(*.ts?(x)|*.js?(x))|*.json|*.css|*.html|*.md)\""
  },
  "dependencies": {
    "dustjs-helpers": "1.7.4",
    "dustjs-linkedin": "2.7.5",
    "esbuild": "0.28.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/express": "5.0.6",
    "@types/morgan": "1.9.10",
    "@types/node": "25.6.0",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "express": "5.2.1",
    "glob": "13.0.6",
    "globals": "17.5.0",
    "morgan": "1.10.1",
    "prettier": "3.8.2",
    "typescript": "6.0.2"
  },
  "prettier": {},
  "engines": {
    "node": ">=18.x"
  },
  "license": "Apache-2.0"
}
