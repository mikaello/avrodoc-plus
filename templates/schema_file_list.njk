<h1>{{ page_title }}</h1>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Root Type</th>
            <th>Filename</th>
            <th>Description</th>
        </tr>
    </thead>

    <tbody>
    {% for schema in schemata %}
        <tr>
            <td class="type">{{ schema.root_type | inlineType | safe }}</td>
            <td class="filename">{{ schema.filename }}</td>
            <td class="root-type-doc">{{ schema.root_type.doc | markdown | safe }}</td>
        </tr>
    {% endfor %}
    </tbody>
</table>
